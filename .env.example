# Admin login (defaults: admin123 / dt_admin_token_v1)
ADMIN_PASSWORD=change-this-strong-password
ADMIN_TOKEN=change-this-to-a-long-random-string

# Groq API — generates MCQs from news + parses unstructured PDFs/Word
# Get one at https://console.groq.com
GROQ_API_KEY=

# NewsAPI.org — daily current affairs source
# Free tier: 100 req/day, India-filtered top headlines
# Get one at https://newsapi.org
NEWS_API_KEY=

# Cron secret — required to authorise the daily-quiz webhook at 8 AM IST
# Generate with:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
CRON_SECRET=
