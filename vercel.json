{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "crons": [
    {
      "path": "/api/cron/fetch-news",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-affairs",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/daily-quiz",
      "schedule": "0 8 * * *"
    }
  ]
}
